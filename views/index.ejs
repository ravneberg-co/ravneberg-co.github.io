		<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
		<script type="module" src="/js/main.js"></script>
<% if (isDev) { %>
		<script src="//localhost:35729/livereload.js?snipver=1" async defer></script>
<% } %>
