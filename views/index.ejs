		<%- include('partials/header') %>
		<%- include('partials/scroll') %>
		<%- include('partials/nav') %>

		<main>
			<div id="view-home">
				<%- include('pages/hero') %>
				<%- include('pages/norrn') %>
				<%- include('pages/stig') %>
			</div>
