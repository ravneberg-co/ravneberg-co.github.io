					/>
				</svg>
			</span>
		</button>

		<button class="fullscreen-toggle" aria-label="Toggle fullscreen">
			<svg class="fullscreen-toggle__enter" viewBox="0 0 24 24">
				<path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z" />
			</svg>
			<svg class="fullscreen-toggle__exit" viewBox="0 0 24 24">
				<path d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z" />
			</svg>
		</button>

		<a href="/stats" class="stats-toggle" aria-label="Analytics">
			<svg viewBox="0 0 24 24"><path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/></svg>
